# Copy to .env and fill in. Used by docker-compose. Dev-only —
# production must source these from a real secret store.
#
#   cp .env.example .env
#   # then put a fresh secret in SECRET_KEY_BASE:
#   mix phx.gen.secret

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=camelot

DATABASE_URL=ecto://postgres:postgres@db/camelot
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000
POOL_SIZE=10

# Mail (OCI Email Delivery via SMTP relay)
SMTP_RELAY=smtp.email.us-ashburn-1.oci.oraclecloud.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@camelotai.tech
MAIL_FROM_NAME=Camelot
